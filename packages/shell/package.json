{
  "name": "@systemforge/shell",
  "version": "0.1.0",
  "description": "Application shell components for SystemForge applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "@systemforge/auth": "workspace:*",
    "@systemforge/tenant": "workspace:*",
    "@systemforge/ui": "workspace:*"
  },
  "devDependencies": {
    "@systemforge/auth": "workspace:*",
    "@systemforge/tenant": "workspace:*",
    "@systemforge/ui": "workspace:*",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "systemforge",
    "shell",
    "layout",
    "navigation"
  ],
  "author": "SystemForge Team",
  "license": "MIT"
}
