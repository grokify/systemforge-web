{
  "name": "@coreforge/shell",
  "version": "0.1.0",
  "description": "Application shell components for CoreForge applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "@coreforge/auth": "workspace:*",
    "@coreforge/tenant": "workspace:*",
    "@coreforge/ui": "workspace:*"
  },
  "devDependencies": {
    "@coreforge/auth": "workspace:*",
    "@coreforge/tenant": "workspace:*",
    "@coreforge/ui": "workspace:*",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "coreforge",
    "shell",
    "layout",
    "navigation"
  ],
  "author": "CoreForge Team",
  "license": "MIT"
}
