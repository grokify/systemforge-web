{
  "name": "@coreforge/telemetry",
  "version": "0.1.0",
  "description": "Telemetry, error tracking, and performance monitoring for CoreForge applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "coreforge",
    "telemetry",
    "monitoring",
    "error-tracking",
    "observability"
  ],
  "author": "CoreForge Team",
  "license": "MIT"
}
